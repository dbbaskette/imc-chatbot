# IMC Chatbot Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration (optional - defaults shown)
# SERVER_PORT=8080

# Logging Configuration (optional)
# LOG_LEVEL=INFO
# SPRING_AI_LOG_LEVEL=INFO

# MCP Server Configuration (optional - for connecting to MCP tool servers)
# Enable MCP tools (requires running MCP servers)
# MCP_TOOLS_ENABLED=false

# Local MCP server endpoints (if running locally)
# POLICY_MCP_URL=http://localhost:3001/sse
# ACCIDENT_MCP_URL=http://localhost:3002/sse

# Cloud MCP server endpoints (if using hosted servers)
# POLICY_MCP_URL=https://your-policy-server.com
# POLICY_MCP_SSE_ENDPOINT=/sse
# ACCIDENT_MCP_URL=https://your-accident-server.com/sse

# Cloud Foundry Configuration (only needed for cloud profile)
# These are typically provided by bound services in CF
# CF_CHAT_MODEL_URL=your_cf_model_url
# CF_CHAT_MODEL_API_KEY=your_cf_api_key